# --- Binarios y Compilación ---
# Compilados de Go
bin/
out/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
main

# Si solés compilar el binario con un nombre específico (ej. shelter-api)
refugio-core
shelter-api

# --- Dependencias ---
# Solo ignoramos vendor si no lo usás explícitamente (Go Modules es el estándar ahora)
# vendor/

# --- Variables de Entorno y Secretos ---
# NUNCA subir archivos con credenciales de base de datos o API Keys
.env
.env.local
.env.*.local

# --- Docker ---
# Archivos de datos de Postgres (para que no se suba tu DB local al repo)
postgres-data/
pgdata/

# --- Herramientas de Desarrollo ---
# Logs del servidor
*.log

# Archivos de JetBrains (GoLand, IntelliJ)
.idea/
*.iws
*.iml
*.ipr

# Archivos de VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# --- Sistema Operativo ---
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# --- Testing ---
# Archivos de cobertura de tests
*.out
*.test
coverage.txt
